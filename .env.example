# ============================================================
#  GROWW PREDICTOR — environment configuration
#  Copy this file to ".env" and fill in your credentials.
# ============================================================

# ---- AUTH: pick ONE of the three modes below ----------------
#
#  MODE 1 (simplest): a daily Access Token.
#    Generate from Groww > Settings > Trading APIs > Access Token.
#    NOTE: it expires every day at 6:00 AM IST, so you must paste
#    a fresh one each morning (or use MODE 2 / 3 to auto-generate).
GROWW_ACCESS_TOKEN=

#  MODE 2: API Key + Secret (auto-generates a token each run).
#    Requires daily approval on the Groww Cloud API Keys page.
GROWW_API_KEY=
GROWW_API_SECRET=

#  MODE 3: API Key + TOTP (auto-generates a token each run).
#    Use the TOTP secret shown when you enable TOTP for the key.
#    (requires `pip install pyotp`)
GROWW_TOTP_SECRET=
# (GROWW_API_KEY above is reused for this mode)

# ---- PREDICTION SETTINGS ------------------------------------
# What does "most traded" mean to you?
#   turnover  = value traded in rupees (volume x price)   <-- recommended, this is "most active by value"
#   volume    = number of shares traded (favours cheap stocks like penny scrips)
RANK_METRIC=turnover

# Opening window (IST). The market opens 09:15; we read the first 10 minutes.
OPEN_FROM=09:15
OPEN_TO=09:25

# How many names to scan. Universe = NSE F&O underlyings by default
# (the ~190 most liquid stocks — the day's most-traded is almost always here).
UNIVERSE=FNO            # FNO | NIFTY200 | CUSTOM
CUSTOM_SYMBOLS=         # comma list used only when UNIVERSE=CUSTOM, e.g. RELIANCE,TCS,SBIN

# Model: "auto" uses the trained LightGBM ranker if a model file exists,
# otherwise falls back to the transparent analytic projector.
MODEL_MODE=auto         # auto | analytic | lgbm

# History depth for building the training/backtest dataset (calendar days).
HISTORY_DAYS=60

# Where artefacts are written
DATA_DIR=./data
